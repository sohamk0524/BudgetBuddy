# Plaid API credentials (from https://dashboard.plaid.com)
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox

# Fernet encryption key for Plaid access tokens
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_generated_fernet_key

# Google Cloud credentials (for Datastore)
# Download service account JSON from Google Cloud Console → IAM → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=google-auth.json

# Firebase Admin SDK credentials (for phone auth verification)
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS=firebase-adminsdk.json

# Anthropic API key (from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Tavily API key for RAG search (from https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key

FLASK_ENV=development
