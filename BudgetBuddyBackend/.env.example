# Plaid API credentials (from https://dashboard.plaid.com)
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox

# Fernet encryption key for Plaid access tokens
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_generated_fernet_key

# Tavily API key for school-specific RAG search (from https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key

# Local development: set to "true" to use Datastore emulator instead of cloud
# Start emulator first: bash start_local_db.sh
USE_LOCAL_DB=false
